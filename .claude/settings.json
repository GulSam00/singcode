{
  "permissions": {
    "defaultMode": "bypassPermissions"
  },

  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git fetch --prune 2>&1 && git branch -vv | awk '/: gone]/{print $1}' | xargs -r git branch -D 2>&1 || true",
            "timeout": 30,
            "statusMessage": "원격 삭제된 브랜치 정리 중..."
          }
        ]
      }
    ]
  }
}
